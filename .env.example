PGHOST=localhost
PGPORT=5432
PGDATABASE=pokemon
PGUSER=postgres
PGPASSWORD=
PORT=3001

# --- Google OAuth — https://console.cloud.google.com → Identifiants → OAuth 2.0 ---
# Origines autorisées : http://localhost:5173 et http://localhost:3001
GOOGLE_CLIENT_ID=

# Même valeur que GOOGLE_CLIENT_ID (exposée au frontend Vite)
VITE_GOOGLE_CLIENT_ID=

# --- Hermes Agent (Référentiel IA) — instance VPS auto-hébergée, accès via SSH ---
HERMES_SSH_HOST=
HERMES_SSH_USER=hermes
HERMES_SSH_KEY_PATH=
HERMES_SSH_BIN=/home/hermes/.local/bin/hermes

# --- Sources de prix (mise à jour automatique de la collection) ---

# eBay Browse API (gratuit) — https://developer.ebay.com
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=
EBAY_MARKETPLACE=EBAY_FR

# Cardmarket API (compte vendeur requis) — laissez vide tant que non obtenu
CM_APP_TOKEN=
CM_APP_SECRET=
CM_ACCESS_TOKEN=
CM_ACCESS_SECRET=

# Vinted (scraping) — passez à true pour l'activer
VINTED_ENABLED=false
# Proxy Oxylabs (fourni avec Hermes Agent) — recommandé pour Vinted/eBay sans API
OXYLABS_USERNAME=
OXYLABS_PASSWORD=
